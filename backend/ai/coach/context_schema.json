{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PeeNgernCoachContext",
  "description": "ข้อมูล real-time ที่ฉีดเข้า system prompt ก่อนถาม LLM (จำนวนเงินทุกค่า = สตางค์). ตัด PII ออกแล้ว.",
  "type": "object",
  "required": ["monthly_income", "this_month_spent"],
  "properties": {
    "monthly_income": { "type": "integer", "description": "รายได้/เดือน (สตางค์)" },
    "this_month_spent": { "type": "integer", "description": "ใช้ไปเดือนนี้ (สตางค์)" },
    "budget_remaining": {
      "type": "object",
      "additionalProperties": { "type": "integer" },
      "description": "งบคงเหลือต่อหมวด (สตางค์; ค่าลบ = เกินงบ)"
    },
    "top_expenses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": { "type": "string" },
          "amount": { "type": "integer" }
        }
      }
    },
    "goals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "progress_pct": { "type": "number" }
        }
      }
    },
    "streak_days": { "type": "integer" }
  }
}

# ── Dev (default): SQLite — ไม่ต้องลง service อะไรเลย ───────────────
DATABASE_URL="file:./dev.db"

# ── Staging/Prod: PostgreSQL ──────────────────────────────────────
# 1) เปลี่ยน provider ใน prisma/schema.prisma:  provider = "postgresql"
# 2) ใช้ connection string จริง (เช่น Neon / Supabase / Railway — ฟรี, ไม่ต้องใช้ Docker):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/finance_coach?schema=public"
# 3) npx prisma migrate dev --name init

JWT_SECRET="change-me-please-use-a-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=4000
CORS_ORIGIN="*"

# ── AI Coach "พี่เงิน" ── ไม่ใส่ key ก็ได้ (ใช้ fallback rule-based ตอบจากข้อมูลจริง)
# ใส่ตัวไหน ตัวนั้นถูกใช้ · ลำดับการลอง: Typhoon → Groq → OpenAI → fallback
# Typhoon (ไทยดีสุด) — key จาก https://opentyphoon.ai
# TYPHOON_API_KEY="sk-..."
# TYPHOON_MODEL="typhoon-v2.5-30b-a3b-instruct"
# Groq (เร็ว, ฟรี) — key จาก https://console.groq.com
# GROQ_API_KEY="gsk_..."
# GROQ_MODEL="llama-3.3-70b-versatile"
# OpenAI/ChatGPT (หรือ endpoint OpenAI-compatible อื่นผ่าน OPENAI_BASE_URL)
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-3.5-turbo"
